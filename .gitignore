# ---- Data (never commit the H&M dataset — it's licensed) ----
# Raw + intermediate data all lives under data/, so ignore the whole tree.
data/
*.parquet
*.feather

# ---- Model artifacts & embeddings (too large for git) ----
*.model
*.bin
*.pkl
*.pickle
*.npy
*.npz
*.pt
*.pth
*.txt.gz
embeddings/
checkpoints/
outputs/*.txt                   # saved LightGBM boosters (lgbm_ranker_*.txt)

# ---- Outputs: keep small result tables + figures, drop the heavy stuff ----
# (*.parquet / *.pkl above already exclude the large intermediate artifacts)
submissions/
*.csv.gz

# ---- Notebooks ----
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.python-version

# ---- Kaggle / secrets ----
kaggle.json
.env
*.key

# ---- OS / editor ----
.DS_Store
Thumbs.db
.idea/
.vscode/
